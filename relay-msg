#!/usr/bin/env python3
"""
Agent Relay — Inter-agent messaging for AI coding agents.

Usage:
  relay-msg send <target> <message>    Send a message to an agent or group
  relay-msg check                      Check for unread messages (marks as read)
  relay-msg check --peek               Check unread without marking as read
  relay-msg check --history            Show all messages including already-read
  relay-msg register <name> [options]  Register this agent
  relay-msg unregister <name>          Remove an agent
  relay-msg list                       List registered agents and groups

Options for register:
  --group <name>       Add agent to a group (repeatable)
  --cwd <pattern>      CWD pattern for auto-detection
  --transport local    How this agent connects to MySQL: "local" (direct) or "remote" (via proxy)
  --alias <name>       Alternate name this agent also receives messages for (repeatable)

Agents self-register into a relay_agents table. No hardcoded peers.
Groups are derived from agent registrations — no hardcoded broadcast lists.

Messages are stored in MySQL/MariaDB or SQLite. Read messages are marked with
read_at (not deleted) to preserve conversation history.

Configuration via .relay-env file (gitignored) or environment variables:
  RELAY_DB_DRIVER    "mysql" (default) or "sqlite"
  RELAY_DB_USER      MySQL user (default: root)              [mysql only]
  RELAY_DB_PASS      MySQL password (default: root)           [mysql only]
  RELAY_DB_NAME      MySQL database name (default: agent_relay)   [mysql only]
  RELAY_DB_PATH      SQLite file path (default: ~/.agent-relay.sqlite3)  [sqlite only]
  RELAY_IDENTITY     Force agent identity (skips auto-detection)
  RELAY_TRANSPORT    "local" or "remote" (default: local)     [mysql only]
  RELAY_PROXY_CMD    Command to proxy MySQL for remote agents (optional, mysql only)
"""
import sys
import os
import subprocess


def _load_env_file():
    """Load .relay-env from the script's directory or the repo root (two levels up).

    File format: KEY=VALUE (one per line, no export, no quotes required).
    Skips blank lines and comments (#).
    Does NOT override values already set in the environment.
    """
    candidates = [
        os.path.join(os.path.dirname(os.path.abspath(__file__)), ".relay-env"),
        os.path.join(os.path.dirname(os.path.abspath(__file__)), "..", "..", ".relay-env"),
    ]
    for path in candidates:
        path = os.path.abspath(path)
        if os.path.isfile(path):
            with open(path) as f:
                for line in f:
                    line = line.strip()
                    if not line or line.startswith("#"):
                        continue
                    if "=" in line:
                        key, _, value = line.partition("=")
                        key = key.strip()
                        value = value.strip()
                        # Only strip outer quotes if they form a symmetric pair.
                        if len(value) >= 2 and value[0] == value[-1] and value[0] in ("'", '"'):
                            value = value[1:-1]
                        if key and key not in os.environ:
                            os.environ[key] = value
            break


_load_env_file()

DB_DRIVER = os.environ.get("RELAY_DB_DRIVER", "mysql").strip().lower()
DB_USER = os.environ.get("RELAY_DB_USER", "root")
DB_PASS = os.environ.get("RELAY_DB_PASS", "root")
DB_NAME = os.environ.get("RELAY_DB_NAME", "agent_relay")
DB_PATH = os.path.expanduser(os.environ.get("RELAY_DB_PATH", "~/.agent-relay.sqlite3"))

_schema_checked = False


def _is_sqlite():
    return DB_DRIVER == "sqlite"


def _sqlite_cmd(sql):
    """Build a sqlite3 CLI invocation matching mysql's -N -B output shape
    (tab-separated, no headers, NULL rendered as the literal string NULL)."""
    return ["sqlite3", "-batch", "-noheader", "-separator", "\t",
            "-nullvalue", "NULL", DB_PATH, sql]


def _mysql_local_cmd(sql):
    return ["mysql", "-u", DB_USER, f"-p{DB_PASS}",
            "--default-character-set=utf8mb4", "-N", "-B", DB_NAME, "-e", sql]


def _mysql_remote_shellcmd(sql):
    """Single-quote-escaped mysql command for the shell=True proxy path."""
    safe_sql = sql.replace("'", "'\\''")
    return (f"mysql -u {DB_USER} -p{DB_PASS} --default-character-set=utf8mb4 "
            f"-N -B {DB_NAME} -e '{safe_sql}'")


def _mysql_remote_quoted_cmdstr(sql):
    """Double-quote-escaped mysql command string for the direct-invocation path.
    Inner single quotes (SQL string literals) survive the intermediate
    run-cmd → sh layer because we double-quote -e and escape shell-meaningful
    characters inside the double-quoted string."""
    escaped = (sql.replace("\\", "\\\\")
                  .replace('"', '\\"')
                  .replace('$', '\\$')
                  .replace('`', '\\`'))
    return (f'mysql -u {DB_USER} -p{DB_PASS} --default-character-set=utf8mb4 '
            f'-N -B {DB_NAME} -e "{escaped}"')


def detect_self():
    """Detect which agent is running this script.

    Priority:
      1. RELAY_IDENTITY env var — always wins
      2. CWD patterns from relay_agents table
      3. Falls back to "default"
    """
    identity = os.environ.get("RELAY_IDENTITY")
    if identity:
        return identity

    # Try CWD-based detection from registered agents.
    cwd = os.getcwd()
    try:
        rows = run_sql_raw(
            "SELECT name, cwd_pattern FROM relay_agents WHERE cwd_pattern IS NOT NULL AND cwd_pattern != ''",
            fetch=True,
        )
        for row in rows:
            parts = row.split("\t", 1)
            if len(parts) == 2 and parts[1] in cwd:
                return parts[0]
    except SystemExit:
        pass

    return "default"


def run_sql(sql, fetch=False):
    """Run SQL. Routes through proxy for remote mysql agents; sqlite is always local."""
    if _is_sqlite():
        result = subprocess.run(_sqlite_cmd(sql), capture_output=True, text=True, timeout=10)
        if result.returncode != 0:
            print(f"SQLite error: {result.stderr.strip()}", file=sys.stderr)
            sys.exit(2)
        return result.stdout.strip().splitlines() if fetch else []

    me_transport = _get_transport()

    if me_transport == "local":
        result = subprocess.run(_mysql_local_cmd(sql), capture_output=True, text=True, timeout=10)
        if result.returncode != 0:
            print(f"MySQL error: {result.stderr.strip()}", file=sys.stderr)
            sys.exit(2)
        return result.stdout.strip().splitlines() if fetch else []
    else:
        # Remote: two invocation styles.
        # - User-supplied RELAY_PROXY_CMD → legacy shell=True pipeline so
        #   custom proxies (ssh, docker exec, etc.) keep working.
        # - Auto-detected bin/run-cmd → direct Python argv invocation with
        #   double-quoted -e (cowork-style). Bypasses multi-layer shell
        #   quoting that previously corrupted SQL single quotes in
        #   Python → sh → run-cmd → watcher → sh pipelines.
        user_proxy = os.environ.get("RELAY_PROXY_CMD")
        if user_proxy:
            mysql_cmd = _mysql_remote_shellcmd(sql)
            full_cmd = user_proxy.replace("{}", mysql_cmd) if "{}" in user_proxy else f"{user_proxy} {mysql_cmd}"
            result = subprocess.run(full_cmd, shell=True,
                                    capture_output=True, text=True, timeout=20)
        else:
            run_cmd = _find_run_cmd()
            if not run_cmd:
                print("Remote transport requires RELAY_PROXY_CMD or bin/run-cmd relative to the relay script.",
                      file=sys.stderr)
                sys.exit(2)
            mysql_cmd = _mysql_remote_quoted_cmdstr(sql)
            result = subprocess.run(["python3", run_cmd, "local", mysql_cmd],
                                    capture_output=True, text=True, timeout=20)
        if result.returncode != 0:
            err = result.stderr.strip() or "timed out waiting for MySQL result"
            print(f"Relay error: {err}", file=sys.stderr)
            sys.exit(2)
        return result.stdout.strip().splitlines() if fetch else []


def _get_transport():
    """Determine transport for current agent: 'local' or 'remote'."""
    me = detect_self()
    try:
        rows = run_sql_raw(
            f"SELECT transport FROM relay_agents WHERE name = '{_esc(me)}' LIMIT 1",
            fetch=True,
        )
        if rows and rows[0].strip():
            return rows[0].strip()
    except Exception:
        pass
    return "local"


def _get_proxy_cmd():
    """Get the proxy command for remote MySQL access (legacy — kept for compat)."""
    proxy = os.environ.get("RELAY_PROXY_CMD")
    if proxy:
        return proxy
    # Try to find a run-cmd script relative to this script.
    script_dir = os.path.dirname(os.path.abspath(__file__))
    candidate = os.path.join(script_dir, "..", "..", "bin", "run-cmd")
    if os.path.exists(candidate):
        return f"python3 {os.path.abspath(candidate)} local"
    return None


def _find_run_cmd():
    """Locate bin/run-cmd relative to this script. Returns absolute path or None."""
    script_dir = os.path.dirname(os.path.abspath(__file__))
    candidate = os.path.join(script_dir, "..", "..", "bin", "run-cmd")
    abspath = os.path.abspath(candidate)
    if os.path.exists(abspath):
        return abspath
    return None


def run_sql_raw(sql, fetch=False):
    """Bootstrap SQL — respects RELAY_TRANSPORT env var for remote agents.

    Unlike run_sql(), this does NOT call detect_self() or _get_transport()
    (which would cause infinite recursion). Instead it reads transport
    directly from RELAY_TRANSPORT env var or .relay-env.
    """
    if _is_sqlite():
        result = subprocess.run(_sqlite_cmd(sql), capture_output=True, text=True, timeout=10)
        if result.returncode != 0:
            return [] if fetch else None
        return result.stdout.strip().splitlines() if fetch else []

    transport = os.environ.get("RELAY_TRANSPORT", "local")

    if transport == "remote":
        user_proxy = os.environ.get("RELAY_PROXY_CMD")
        if user_proxy:
            mysql_cmd = _mysql_remote_shellcmd(sql)
            full_cmd = user_proxy.replace("{}", mysql_cmd) if "{}" in user_proxy else f"{user_proxy} {mysql_cmd}"
            result = subprocess.run(full_cmd, shell=True,
                                    capture_output=True, text=True, timeout=20)
        else:
            run_cmd = _find_run_cmd()
            if not run_cmd:
                return [] if fetch else None
            mysql_cmd = _mysql_remote_quoted_cmdstr(sql)
            result = subprocess.run(["python3", run_cmd, "local", mysql_cmd],
                                    capture_output=True, text=True, timeout=20)
        if result.returncode != 0:
            return [] if fetch else None
        return result.stdout.strip().splitlines() if fetch else []
    else:
        result = subprocess.run(_mysql_local_cmd(sql), capture_output=True, text=True, timeout=10)
        if result.returncode != 0:
            return [] if fetch else None
        return result.stdout.strip().splitlines() if fetch else []


def _esc(s):
    """Escape a string for SQL single-quote contexts."""
    return s.replace("\\", "\\\\").replace("'", "\\'")


_MYSQL_SCHEMA = [
    """CREATE TABLE IF NOT EXISTS relay_agents (
        name VARCHAR(40) PRIMARY KEY,
        transport ENUM('local','remote') NOT NULL DEFAULT 'local',
        cwd_pattern VARCHAR(255) DEFAULT NULL,
        registered_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP
    ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4""",
    """CREATE TABLE IF NOT EXISTS relay_agent_groups (
        agent_name VARCHAR(40) NOT NULL,
        group_name VARCHAR(40) NOT NULL,
        PRIMARY KEY (agent_name, group_name),
        FOREIGN KEY (agent_name) REFERENCES relay_agents(name) ON DELETE CASCADE
    ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4""",
    """CREATE TABLE IF NOT EXISTS relay_agent_aliases (
        alias_name VARCHAR(40) PRIMARY KEY,
        agent_name VARCHAR(40) NOT NULL,
        FOREIGN KEY (agent_name) REFERENCES relay_agents(name) ON DELETE CASCADE
    ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4""",
    """CREATE TABLE IF NOT EXISTS relay_messages (
        id INT AUTO_INCREMENT PRIMARY KEY,
        target VARCHAR(40) NOT NULL,
        sender VARCHAR(40) NOT NULL,
        message TEXT NOT NULL,
        created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
        read_at TIMESTAMP NULL DEFAULT NULL,
        KEY idx_target (target),
        KEY idx_read_at (read_at)
    ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4""",
]

# SQLite: no ENUM (use CHECK), no inline KEY (separate CREATE INDEX), no engine.
# AUTOINCREMENT requires INTEGER PRIMARY KEY. FKs work but only enforce when
# `PRAGMA foreign_keys = ON` is set per-connection — we don't rely on cascade
# semantics since register explicitly clears dependent rows.
_SQLITE_SCHEMA = [
    """CREATE TABLE IF NOT EXISTS relay_agents (
        name TEXT PRIMARY KEY,
        transport TEXT NOT NULL DEFAULT 'local' CHECK (transport IN ('local','remote')),
        cwd_pattern TEXT DEFAULT NULL,
        registered_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP
    )""",
    """CREATE TABLE IF NOT EXISTS relay_agent_groups (
        agent_name TEXT NOT NULL,
        group_name TEXT NOT NULL,
        PRIMARY KEY (agent_name, group_name)
    )""",
    """CREATE TABLE IF NOT EXISTS relay_agent_aliases (
        alias_name TEXT PRIMARY KEY,
        agent_name TEXT NOT NULL
    )""",
    """CREATE TABLE IF NOT EXISTS relay_messages (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        target TEXT NOT NULL,
        sender TEXT NOT NULL,
        message TEXT NOT NULL,
        created_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP,
        read_at TEXT DEFAULT NULL
    )""",
    "CREATE INDEX IF NOT EXISTS idx_target ON relay_messages (target)",
    "CREATE INDEX IF NOT EXISTS idx_read_at ON relay_messages (read_at)",
]


def ensure_schema():
    """Idempotent: create tables if they don't exist."""
    global _schema_checked
    if _schema_checked:
        return
    _schema_checked = True
    stmts = _SQLITE_SCHEMA if _is_sqlite() else _MYSQL_SCHEMA
    try:
        for s in stmts:
            run_sql_raw(s)
    except SystemExit:
        pass


# ── Commands ────────────────────────────────────────────────────────────


def _upsert_clause(conflict_col, update_pairs):
    """Return the dialect-specific tail of an upsert INSERT statement.
    `update_pairs` is a list of "col=value" strings (already escaped)."""
    sets = ", ".join(update_pairs)
    if _is_sqlite():
        return f"ON CONFLICT({conflict_col}) DO UPDATE SET {sets}"
    return f"ON DUPLICATE KEY UPDATE {sets}"


def cmd_register(name, groups=None, cwd_pattern=None, transport="local", aliases=None):
    """Register an agent."""
    ensure_schema()
    safe_name = _esc(name)
    safe_cwd = f"'{_esc(cwd_pattern)}'" if cwd_pattern else "NULL"
    upsert = _upsert_clause("name", [f"transport='{_esc(transport)}'", f"cwd_pattern={safe_cwd}"])
    run_sql(
        f"INSERT INTO relay_agents (name, transport, cwd_pattern) "
        f"VALUES ('{safe_name}', '{_esc(transport)}', {safe_cwd}) {upsert}"
    )
    # Clear old groups and set new ones.
    run_sql(f"DELETE FROM relay_agent_groups WHERE agent_name = '{safe_name}'")
    for g in (groups or []):
        run_sql(
            f"INSERT INTO relay_agent_groups (agent_name, group_name) "
            f"VALUES ('{safe_name}', '{_esc(g)}')"
        )
    # Clear old aliases and set new ones.
    run_sql(f"DELETE FROM relay_agent_aliases WHERE agent_name = '{safe_name}'")
    alias_upsert = _upsert_clause("alias_name", [f"agent_name = '{safe_name}'"])
    for a in (aliases or []):
        run_sql(
            f"INSERT INTO relay_agent_aliases (alias_name, agent_name) "
            f"VALUES ('{_esc(a)}', '{safe_name}') {alias_upsert}"
        )
    parts = []
    if groups:
        parts.append(f"groups: {', '.join(groups)}")
    if aliases:
        parts.append(f"aliases: {', '.join(aliases)}")
    extra = f" ({'; '.join(parts)})" if parts else ""
    print(f"Registered: {name}{extra}")


def cmd_unregister(name):
    """Remove an agent."""
    ensure_schema()
    run_sql(f"DELETE FROM relay_agents WHERE name = '{_esc(name)}'")
    print(f"Unregistered: {name}")


def cmd_list():
    """List all registered agents and groups."""
    ensure_schema()
    if _is_sqlite():
        # SQLite's GROUP_CONCAT(DISTINCT x) doesn't take a custom separator,
        # so it emits comma-joined. REPLACE adds the space for display parity.
        groups_col = "REPLACE(GROUP_CONCAT(DISTINCT g.group_name), ',', ', ')"
        aliases_col = "REPLACE(GROUP_CONCAT(DISTINCT al.alias_name), ',', ', ')"
    else:
        groups_col = "GROUP_CONCAT(DISTINCT g.group_name ORDER BY g.group_name SEPARATOR ', ')"
        aliases_col = "GROUP_CONCAT(DISTINCT al.alias_name ORDER BY al.alias_name SEPARATOR ', ')"
    rows = run_sql(
        f"SELECT a.name, a.transport, a.cwd_pattern, "
        f"{groups_col} AS groups, {aliases_col} AS aliases "
        "FROM relay_agents a "
        "LEFT JOIN relay_agent_groups g ON a.name = g.agent_name "
        "LEFT JOIN relay_agent_aliases al ON a.name = al.agent_name "
        "GROUP BY a.name ORDER BY a.name",
        fetch=True,
    )
    if not rows:
        print("No agents registered.")
        return
    print(f"{'Agent':<15} {'Transport':<10} {'Groups':<20} {'Aliases':<20} {'CWD Pattern'}")
    print("-" * 85)
    for row in rows:
        parts = row.split("\t", 4)
        name = parts[0] if len(parts) > 0 else ""
        transport = parts[1] if len(parts) > 1 else ""
        cwd = parts[2] if len(parts) > 2 and parts[2] != "NULL" else ""
        groups = parts[3] if len(parts) > 3 and parts[3] != "NULL" else ""
        aliases = parts[4] if len(parts) > 4 and parts[4] != "NULL" else ""
        print(f"{name:<15} {transport:<10} {groups:<20} {aliases:<20} {cwd}")


def _get_group_members(group_name):
    """Get all agent names in a group."""
    rows = run_sql(
        f"SELECT agent_name FROM relay_agent_groups WHERE group_name = '{_esc(group_name)}'",
        fetch=True,
    )
    return [r.strip() for r in rows if r.strip()]


def _get_all_agents():
    """Get all registered agent names."""
    rows = run_sql("SELECT name FROM relay_agents", fetch=True)
    return [r.strip() for r in rows if r.strip()]


def _get_all_groups():
    """Get all distinct group names."""
    rows = run_sql("SELECT DISTINCT group_name FROM relay_agent_groups", fetch=True)
    return [r.strip() for r in rows if r.strip()]


def _resolve_alias(name):
    """Resolve an alias to an agent name, or return the name as-is."""
    rows = run_sql(
        f"SELECT agent_name FROM relay_agent_aliases WHERE alias_name = '{_esc(name)}' LIMIT 1",
        fetch=True,
    )
    if rows and rows[0].strip():
        return rows[0].strip()
    return name


def _get_aliases(agent_name):
    """Get all aliases for an agent."""
    rows = run_sql(
        f"SELECT alias_name FROM relay_agent_aliases WHERE agent_name = '{_esc(agent_name)}'",
        fetch=True,
    )
    return [r.strip() for r in rows if r.strip()]


def cmd_send(target, message):
    """Send a message to an agent or group."""
    ensure_schema()
    me = detect_self()

    all_agents = _get_all_agents()
    all_groups = _get_all_groups()

    # Special target: "all" broadcasts to every agent except sender.
    if target == "all":
        recipients = [a for a in all_agents if a != me]
        if not recipients:
            print("No other agents registered.", file=sys.stderr)
            sys.exit(1)
        message = f"[broadcast] {message}"
    elif target in all_groups:
        recipients = [a for a in _get_group_members(target) if a != me]
        if not recipients:
            print(f"No peers in '{target}' group besides yourself.", file=sys.stderr)
            sys.exit(1)
        message = f"[broadcast:{target}] {message}"
    else:
        # Resolve alias to real agent name.
        resolved = _resolve_alias(target)
        recipients = [resolved]

    safe_msg = _esc(message)
    values = ", ".join(f"('{_esc(r)}', '{_esc(me)}', '{safe_msg}')" for r in recipients)
    run_sql(f"INSERT INTO relay_messages (target, sender, message) VALUES {values}")

    _nudge_recipients(recipients)

    if len(recipients) > 1:
        print(f"Broadcast ({target}) sent to: {', '.join(recipients)}")
    else:
        print(f"Message sent to {recipients[0]}")


def _nudge_recipients(recipients):
    """Best-effort side-effect: drop a `.nudge-<agent>` flag file in
    $RELAY_NUDGE_DIR for each recipient so a cmux-nudge-watcher can wake the
    agent's pane. Controlled by two env vars (typically set in `.relay-env`):

      RELAY_NUDGE_DIR     — directory to write flag files into. Unset = disabled.
      RELAY_NUDGE_AGENTS  — comma-separated allowlist (e.g. "cody,carl,abby").
                            Unset = nudge all recipients.

    Silent no-op if disabled, the dir doesn't exist, or the write fails —
    this is a wake-up optimization, not part of the delivery guarantee.
    """
    nudge_dir = os.environ.get("RELAY_NUDGE_DIR")
    if not nudge_dir:
        return
    allow = os.environ.get("RELAY_NUDGE_AGENTS", "").strip()
    allowlist = {a.strip() for a in allow.split(",") if a.strip()} if allow else None
    for r in recipients:
        if allowlist is not None and r not in allowlist:
            continue
        try:
            with open(os.path.join(nudge_dir, f".nudge-{r}"), "w") as f:
                f.write("check inbox\n")
        except OSError:
            pass


def cmd_check(peek=False, history=False):
    """Check for messages."""
    ensure_schema()
    me = detect_self()

    # Build target clause — include the agent's own name plus any aliases.
    targets = [f"'{_esc(me)}'"]
    aliases = _get_aliases(me)
    for a in aliases:
        targets.append(f"'{_esc(a)}'")
    targets_clause = f"target IN ({', '.join(targets)})"

    if history:
        where = targets_clause
    else:
        where = f"{targets_clause} AND read_at IS NULL"

    lines = run_sql(
        f"SELECT id, sender, created_at, message, read_at "
        f"FROM relay_messages WHERE {where} ORDER BY created_at",
        fetch=True,
    )

    if not lines:
        if history:
            print("No message history.")
        return

    ids = []
    for line in lines:
        parts = line.split("\t", 4)
        if len(parts) >= 4:
            ids.append(parts[0])
            ts = parts[2][:19].replace("T", " ")
            read_marker = " [read]" if len(parts) > 4 and parts[4] != "NULL" else ""
            print(f"[{parts[1]}] ({ts}){read_marker} {parts[3]}")

    # Mark unread as read (unless peeking or viewing history).
    if not peek and not history and ids:
        id_list = ",".join(ids)
        run_sql(f"UPDATE relay_messages SET read_at = CURRENT_TIMESTAMP WHERE id IN ({id_list}) AND read_at IS NULL")


# ── CLI ─────────────────────────────────────────────────────────────────


def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)

    cmd = sys.argv[1]

    if cmd == "send":
        if len(sys.argv) < 4:
            print("Usage: relay-msg send <target> <message>", file=sys.stderr)
            sys.exit(1)
        cmd_send(sys.argv[2], " ".join(sys.argv[3:]))

    elif cmd == "check":
        peek = "--peek" in sys.argv
        history = "--history" in sys.argv
        cmd_check(peek=peek, history=history)

    elif cmd == "register":
        if len(sys.argv) < 3:
            print("Usage: relay-msg register <name> [--group <g>] [--cwd <pattern>] [--transport local|remote] [--alias <name>]", file=sys.stderr)
            sys.exit(1)
        name = sys.argv[2]
        groups = []
        aliases = []
        cwd_pattern = None
        transport = "local"
        i = 3
        while i < len(sys.argv):
            if sys.argv[i] == "--group" and i + 1 < len(sys.argv):
                groups.append(sys.argv[i + 1])
                i += 2
            elif sys.argv[i] == "--cwd" and i + 1 < len(sys.argv):
                cwd_pattern = sys.argv[i + 1]
                i += 2
            elif sys.argv[i] == "--transport" and i + 1 < len(sys.argv):
                transport = sys.argv[i + 1]
                i += 2
            elif sys.argv[i] == "--alias" and i + 1 < len(sys.argv):
                aliases.append(sys.argv[i + 1])
                i += 2
            else:
                i += 1
        cmd_register(name, groups=groups, cwd_pattern=cwd_pattern, transport=transport, aliases=aliases)

    elif cmd == "unregister":
        if len(sys.argv) < 3:
            print("Usage: relay-msg unregister <name>", file=sys.stderr)
            sys.exit(1)
        cmd_unregister(sys.argv[2])

    elif cmd == "list":
        cmd_list()

    else:
        print(f"Unknown command: {cmd}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
